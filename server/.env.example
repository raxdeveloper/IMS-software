# SQLite (default — no Docker needed)
DATABASE_URL="file:./dev.db"

# PostgreSQL (Docker: docker compose up -d, then set provider = "postgresql" in prisma/schema.prisma and run db push)
# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ophthalmic_ims?schema=public"
JWT_SECRET="change-this-to-a-long-random-string-min-16-chars"
PORT=3001
# Bind address (use 0.0.0.0 in Docker / cloud)
# HOST=0.0.0.0
# NODE_ENV=production
# Optional: built SPA folder when API serves the frontend (default: ../client/dist from server cwd)
# CLIENT_DIST=

# Dev: Vite on 5173. Production / Docker: same origin as API (e.g. http://localhost:3001 or your public URL)
CORS_ORIGIN="http://localhost:5173"

# Optional seed overrides
# SEED_ADMIN_EMAIL=admin@clinic.local
# SEED_ADMIN_PASSWORD=ChangeMe123!
# SEED_ADMIN_NAME=System Admin
